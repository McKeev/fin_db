Table "instruments" {
  "instrument_id" bpchar(20) [pk, not null]
  "name" varchar [unique, not null]
  "asset_class" varchar [not null]
  "unit" varchar [not null]
  "internal_ticker" varchar [unique, not null]
}

Table "instrument_attributes" {
  "instrument_id" bpchar(20) [not null]
  "field" varchar [not null]
  "value" varchar [not null]

  Indexes {
    (instrument_id, field) [pk, type: btree, name: "instrument_attributes_pkey"]
  }
}

Table "sources" {
  "name" varchar [pk, not null]
  "priority" int4 [not null]
}

Table "observations" {
  "instrument_id" bpchar(20) [not null]
  "field" varchar [not null]
  "date" date [not null]
  "source" varchar [not null]
  "value" numeric(19,5) [not null]
  "scale" numeric(19,5) [not null]

  Indexes {
    (instrument_id, field, date, source) [pk, type: btree, name: "observations_pkey"]
    (instrument_id, field, date) [type: btree, name: "idx_obs_lookup"]
  }
}

Table "updates" {
  "instrument_id" bpchar(20) [not null]
  "field" varchar [not null]
  "source" varchar [not null]
  "frequency" varchar [not null]
  "last_update" date [not null]

  Indexes {
    (instrument_id, field, source) [pk, type: btree, name: "updates_pkey"]
    (source, frequency, last_update) [type: btree, name: "idx_updates_due_scan"]
    (source, frequency, instrument_id, field) [type: btree, name: "idx_updates_source_frequency_instrument"]
  }
}

Table "ingest_failures" {
  "instrument_id" bpchar(20) [not null]
  "field" varchar [not null]
  "source" varchar [not null]
  "error_timestamp" timestamptz [not null]
  "error_message" varchar

  Indexes {
    (instrument_id, field, source, error_timestamp) [pk, type: btree, name: "ingest_failures_pkey"]
  }
}

Table "identifiers" {
  "instrument_id" bpchar(20) [not null]
  "source" varchar [not null]
  "ext_id" varchar [not null]

  Indexes {
    (instrument_id, source) [pk, type: btree, name: "identifiers_new_pkey"]
    (instrument_id, source, ext_id) [type: btree, unique, name: "identifiers_new_instrument_id_source_ext_id_key"]
    (source, ext_id) [type: btree, name: "idx_identifiers_source_extid"]
  }
}

Ref "identifiers_new_instrument_id_fkey":"instruments"."instrument_id" < "identifiers"."instrument_id"

Ref "identifiers_new_source_fkey":"sources"."name" < "identifiers"."source"

Ref "ingest_failures_instrument_id_fkey":"instruments"."instrument_id" < "ingest_failures"."instrument_id"

Ref "ingest_failures_source_fkey":"sources"."name" < "ingest_failures"."source"

Ref "instrument_attributes_instrument_id_fkey":"instruments"."instrument_id" < "instrument_attributes"."instrument_id"

Ref "observations_instrument_id_fkey":"instruments"."instrument_id" < "observations"."instrument_id"

Ref "observations_source_fkey":"sources"."name" < "observations"."source"

Ref "updates_instrument_id_fkey":"instruments"."instrument_id" < "updates"."instrument_id"

Ref "updates_source_fkey":"sources"."name" < "updates"."source"
