// Use DBML to define your database structure
// Docs: https://dbml.dbdiagram.io/docs

// These are required fields for all instruments
Table instruments {
  instrument_id char(20) [pk]
  name varchar [not null, unique]
  asset_class varchar [not null] // e.g. 'equity', 'bond', 'commodity', etc.
  unit varchar [not null] // could USD, EUR, points, etc.
}

// Need to store for a fast lookup of identifiers for an instrument
// However, we're expecting a lot of missing identifiers
// The general use will be to translate tickers to instrument_id and vice versa
Table identifiers {
  instrument_id char(20) [pk, ref: - instruments.instrument_id]
  ticker varchar [unique]  // Primary display ticker (platform-agnostic)
  isin varchar [unique]
  ric varchar [unique]
  yfin varchar [unique]
  etoro integer [unique]
}

// We want to be able to store any additional attributes for an
// instrument in a flexible way
Table instrument_attributes {
  instrument_id char(20) [pk, ref: > instruments.instrument_id]
  field varchar [pk]
  value varchar [not null]
}

// This table is used to track data sources and their priority for updates and lookups
Table sources {
  name varchar [pk] // e.g. 'YAHOO', 'LSEG', etc..
  priority integer [not null] // lower number = higher priority, used for source selection logic
}

// This is the main table for storing time series data for instruments
// We want to be able to store any type of time series data (price, volume, etc.)
Table observations {
  instrument_id char(20) [pk, ref: > instruments.instrument_id]
  field varchar [pk] // e.g. 'price', 'volume', etc.
  date date [pk]
  source varchar [pk, ref: > sources.name] // tracks data source, can be overwritten with better source
  value numeric(19,4) [not null]
  scale numeric(19,4) [not null] // e.g. 1.0 for price, 0.01 for percentage, etc.

  Indexes {
    (instrument_id, field, date) [name: "idx_obs_lookup"]  // for canonical view
  }
}

// This table is used for updating the time series data (observations)
Table updates {
  instrument_id char(20) [pk, ref: > instruments.instrument_id]
  field varchar [pk] // e.g. 'price', 'volume', etc.
  source varchar [pk, ref: > sources.name] // what source to use for updates
  frequency varchar [not null] // e.g. 'daily', 'weekly', etc.
  last_update date [not null] // when the last successful update occurred

  Indexes {
    (source, frequency, instrument_id, field) [name: "idx_updates_source_frequency_instrument"]
    (source, frequency, last_update) [name: "idx_updates_due_scan"]
  }
}

// Failure log: one row per failed field per run day
Table ingest_failures {
  instrument_id char(20) [pk, ref: > instruments.instrument_id]
  field varchar [pk] // failed field, e.g. close, totret
  source varchar [pk, ref: > sources.name]
  error_timestamp timestampz [pk]

  error_message varchar
}
